# ==========================================
# FRONTEND - VITE Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_KEY=your_supabase_publishable_key_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase Configuration (if still needed)
VITE_apiKey=your_firebase_api_key_here
VITE_authDomain=your_firebase_auth_domain_here
VITE_databaseURL=your_firebase_database_url_here
VITE_projectId=your_firebase_project_id_here
VITE_storageBucket=your_firebase_storage_bucket_here
VITE_messagingSenderId=your_firebase_messaging_sender_id_here
VITE_appId=your_firebase_app_id_here
VITE_measurementId=your_firebase_measurement_id_here

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/

# JWT Secret (for backend communication)
JWT_SECRET=your_jwt_secret_here_minimum_32_chars
